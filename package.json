{
  "name": "suppscanner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css}\" \"api/**/*.js\" \"server.js\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css}\" \"api/**/*.js\" \"server.js\"",
    "preview": "vite preview",
    "server": "node server.js",
    "start": "node server.js",
    "start:full": "concurrently \"npm run dev\" \"npm run server\"",
    "postinstall": "echo 'Puppeteer will install Chromium automatically'",
    "ingest:pubmed": "node scripts/ingest-pubmed.js",
    "ingest:pubmed:dry": "node scripts/ingest-pubmed.js --dry-run",
    "seed:interactions": "node scripts/seed-interactions.js",
    "seed:interactions:dry": "node scripts/seed-interactions.js --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/supabase-js": "^2.95.3",
    "@tailwindcss/postcss": "^4.1.13",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "jsdom": "^27.2.0",
    "lucide-react": "^0.544.0",
    "openai": "^5.23.0",
    "puppeteer": "^24.30.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.14.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "postcss": "^8.5.6",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.3",
    "vite": "^4.4.5"
  }
}
