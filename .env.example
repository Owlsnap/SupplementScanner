# ============================================================
# SupplementScanner — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.
# ============================================================

# ── AI Providers ─────────────────────────────────────────────
# Used for product extraction + normalization (ingest pipeline)
OPENAI_API_KEY=sk-...

# Used for encyclopedia deep dive generation
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the OpenAI model used for extraction
# Default behaviour uses the SDK default if unset
OPENAI_MODEL=gpt-4o

# Optional: Jina API key for enhanced URL scraping pipeline
JINA_API_KEY=

# Optional: enable AI matching in the extraction pipeline (true/false)
ENABLE_AI_MATCHING=true

# ── Supabase ─────────────────────────────────────────────────
# Project URL — find in Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co

# Anon/public key — safe to expose to the browser, used for auth
SUPABASE_ANON_KEY=eyJ...

# Service role key — NEVER expose to the browser, server-side only
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Server ───────────────────────────────────────────────────
# Port the Express server listens on (Railway sets this automatically)
PORT=3001

# ── Web Frontend (Vite) ──────────────────────────────────────
# Optional: override the API URL used by the web frontend
# Defaults to same-origin in production (Express serves both)
VITE_API_URL=http://localhost:3001

# Cookiebot ID for GDPR cookie consent banner
VITE_COOKIEBOT_ID=your-cookiebot-id

# Dev-only: bypass the premium paywall for local testing
# Set to true only in .env.local — never in production
VITE_DEV_PREMIUM_BYPASS=false

# ── Puppeteer ────────────────────────────────────────────────
# Path to system Chromium — required on Railway (Nix environment)
# Leave unset for local development (uses bundled Chromium)
# Railway value: /run/current-system/sw/bin/chromium
PUPPETEER_EXECUTABLE_PATH=
